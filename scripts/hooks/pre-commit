#!/bin/bash
# Pre-commit hook: auto-generate docs + verify data-models (KIK-525)
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Bypass:  git commit --no-verify

SRC_CHANGED=$(git diff --cached --name-only | grep -cE '^src/')
if [ "$SRC_CHANGED" -gt 0 ]; then
  if [ -f "scripts/generate_docs.py" ]; then
    # Auto-generate docs from source
    python3 scripts/generate_docs.py all 2>&1
    git add docs/api-reference.md CLAUDE.md .claude/rules/development.md docs/skill-catalog.md 2>/dev/null

    # Verify data-models.md is in sync with fixtures
    python3 scripts/generate_docs.py data-models-verify 2>&1
    if [ $? -ne 0 ]; then
      echo "⚠️  docs/data-models.md is out of sync. Please update manually."
      exit 1
    fi
  else
    # Fallback: check if docs were updated manually
    DOC_CHANGED=$(git diff --cached --name-only | grep -cE '(CLAUDE\.md|README\.md|SKILL\.md|rules/|config/|docs/)')
    if [ "$DOC_CHANGED" -eq 0 ]; then
      echo "src/ に変更がありますが、ドキュメントが更新されていません。"
      echo "対象: CLAUDE.md, SKILL.md, rules/, config/, README.md, docs/"
      echo "バイパス: git commit --no-verify"
      exit 1
    fi
  fi
fi
